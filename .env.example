# Copy this file to ".env" and fill in real values.
# The eval points at any OpenAI-compatible endpoint (works with most gateways/proxies).
#
#   cp .env.example .env
#
# If you leave these blank, the harness runs in MOCK mode (no network, canned output).

# Base URL of your OpenAI-compatible endpoint (include /v1 if required by your gateway)
OPENAI_API_BASE=

# API key / token for that endpoint
OPENAI_API_KEY=

# Model name your endpoint expects (e.g. gpt-4o-mini, claude-3-5-sonnet, etc.)
MODEL_NAME=gpt-4o-mini

# Set to "1" to force mock mode even if keys are present (useful for offline runs)
MOCK=0
